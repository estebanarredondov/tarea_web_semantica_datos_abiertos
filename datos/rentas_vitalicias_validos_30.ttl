# Datos públicos transformados a RDF
ex:MercadoChile a ex:Mercado ;
    ex:pensionPromedio "9.5"^^xsd:decimal ;
    ex:porcentajeRetiroProgramado "45.4"^^xsd:decimal ;
    ex:porcentajeRentaVitaliciaEscalonada "40.7"^^xsd:decimal .

